# Backend configuration.
# Copy to backend/configs/.env for local dev, or inject these as environment
# variables via your process manager (systemd, Docker, ...) in production.

# Postgres connection string. Comment this out to use the in-memory store
# (no persistence). The password must match the one Postgres runs with.
DATABASE_URL=postgres://gochess:gochess@localhost:5432/gochess

# Secret used to sign auth JWTs — required, must be at least 32 characters.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=

# Add the Secure flag to the auth cookie. Set to true when served over HTTPS
# (e.g. behind a Cloudflare tunnel); keep false for plain-HTTP local dev.
COOKIE_SECURE=false
